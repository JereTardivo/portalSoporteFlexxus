# ── Base de datos (Neon PostgreSQL) ─────────────────────────────────────
# neon.tech → tu proyecto → Connection Details → Connection string
# "Pooled connection" (con pgbouncer=true) → DATABASE_URL
# "Direct connection"                       → DIRECT_URL
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────────
# Generar secreto: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="reemplazar-con-string-aleatorio-largo"
# En Vercel se setea automáticamente. Local: http://localhost:4000
NEXTAUTH_URL="https://tu-app.vercel.app"
